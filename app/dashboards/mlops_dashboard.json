{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Graphics --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Inference Requests Total",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(inference_requests_total[5m])) by (prediction)",
          "legendFormat": "{{prediction}}"
        }
      ]
    },
    {
      "title": "Average Inference Latency (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(inference_latency_ms_sum[5m]) / rate(inference_latency_ms_count[5m])",
          "legendFormat": "Avg Latency"
        }
      ]
    },
    {
      "title": "Drift Score (PSI)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "drift_score{metric_type=\"psi\"}",
          "legendFormat": "PSI"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.2 }
            ]
          }
        }
      }
    },
    {
      "title": "Confidence Distribution",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 8 },
      "targets": [
        {
          "expr": "rate(prediction_confidence_bucket[5m])",
          "format": "heatmap",
          "legendFormat": "{{le}}"
        }
      ]
    },
    {
      "title": "Latency Anomaly (Z-Score)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "latency_anomaly_score",
          "legendFormat": "Z-Score"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 3 }
            ]
          }
        }
      }
    }
  ],
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["MLOps", "NLP"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "",
  "title": "NLP MLOps Dashboard",
  "uid": "mlops-dashboard",
  "version": 1
}
